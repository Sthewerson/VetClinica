{
  "openapi": "3.0.0",
  "info": {
    "title": "API para gerenciar tutores e pets",
    "description": "Esta é uma API para gerenciar tutores e pets, utilizando Node.js, Express, TypeORM e SQLite como banco de dados. A API permite realizar operações CRUD (Criar, Ler, Atualizar, Deletar) em tutores e pets, além de associar pets a tutores.",
    "version": "1.0.0"
  },
  "paths": {
    "/tutors": {
      "get": {
        "summary": "Lista todos os tutores",
        "description": "Retorna uma lista de todos os tutores cadastrados, incluindo informações sobre os pets associados a cada tutor.",
        "tags": ["tutor"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Sucesso",
            "content": {
              "application/json": {
                "example": [
                  {
                    "id": 1,
                    "name": "Jonh Doe",
                    "phone": "85989323895",
                    "email": "jose.abreu@compasso.com",
                    "date_of_birth": "1993-12-12 10:10",
                    "zip_code": "61760000",
                    "pets": [
                      {
                        "id": 1,
                        "name": "Lilo",
                        "species": "dog",
                        "carry": "p",
                        "weight": 5,
                        "date_of_birth": "1993-12-12 10:10"
                      }
                    ]
                  }
                ]
              }
            }
          }
        }
      },
      "post": {
        "summary": "Cria um novo tutor",
        "description": "Cria um novo tutor com os dados fornecidos",
        "tags": ["tutor"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/tutor" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tutor criado com sucesso",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/tutor" }
              }
            }
          },
          "400": {
            "description": "Requisição inválida",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/responses/BadRequest" }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "message": { "type": "string" } },
                  "example": { "message": "Internal server error" }
                }
              }
            }
          }
        }
      }
    },
    "/tutor/{id}": {
      "put": {
        "summary": "Atualiza os dados de um tutor existente",
        "description": "Atualiza os dados de um tutor existente com os dados fornecidos",
        "tags": ["tutor"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "description": "ID do tutor a ser atualizado",
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/tutor" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/tutor" }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/responses/BadRequest" }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Remove um tutor existente",
        "description": "Remove o tutor especificado pelo ID",
        "tags": ["tutor"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "description": "ID do tutor a ser removido",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Ok" },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/responses/BadRequest" }
              }
            }
          }
        }
      }
    },
    "/pet/{tutorId}": {
      "post": {
        "summary": "Associa um novo pet a um tutor",
        "description": "Associa um novo pet ao tutor especificado pelo ID do tutor",
        "tags": ["pet"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "tutorId",
            "required": true,
            "description": "ID do tutor ao qual o pet será associado",
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/pet" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pet associado com sucesso ao tutor",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/pet" }
              }
            }
          },
          "400": {
            "description": "Requisição inválida",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/responses/BadRequest" }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "message": { "type": "string" } },
                  "example": { "message": "Internal server error" }
                }
              }
            }
          }
        }
      }
    },
    "/pet/{petId}/tutor/{tutorId}": {
      "put": {
        "summary": "Atualiza os dados de um pet existente e o associa a um novo tutor",
        "description": "Atualiza os dados de um pet existente e o associa a um novo tutor especificado pelo ID do tutor",
        "tags": ["pet"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "petId",
            "required": true,
            "description": "ID do pet a ser atualizado",
            "schema": { "type": "integer" }
          },
          {
            "in": "path",
            "name": "tutorId",
            "required": true,
            "description": "ID do novo tutor ao qual o pet será associado",
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/pet" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/pet" }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/responses/BadRequest" }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Desassocia um pet de um tutor existente",
        "description": "Desassocia o pet especificado pelo ID do tutor",
        "tags": ["pet"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "petId",
            "required": true,
            "description": "ID do pet a ser desassociado",
            "schema": { "type": "integer" }
          },
          {
            "in": "path",
            "name": "tutorId",
            "required": true,
            "description": "ID do tutor do qual o pet será desassociado",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Ok" },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/responses/BadRequest" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "tutor": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "date_of_birth": { "type": "string", "format": "date-time" },
          "phone": { "type": "string" },
          "zip_code": { "type": "string" }
        }
      },
      "pet": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "species": { "type": "string" },
          "carry": { "type": "string" },
          "weight": { "type": "integer" },
          "date_of_birth": { "type": "string", "format": "date-time" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad Request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  }
}
